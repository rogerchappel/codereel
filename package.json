{
  "name": "codereel",
  "version": "0.1.0",
  "description": "Generate truthful repo walkthrough scripts, storyboards, and verification kits.",
  "type": "module",
  "bin": {
    "codereel": "./bin/codereel.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "test": "node --test",
    "check": "node scripts/validate.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "repo-video",
    "storyboard",
    "devrel",
    "walkthrough"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/codereel.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/codereel/issues"
  },
  "homepage": "https://github.com/rogerchappel/codereel#readme",
  "engines": {
    "node": ">=20"
  }
}
